# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Ghost CMS
GHOST_ADMIN_API_URL=https://your-site.ghost.io
GHOST_ADMIN_API_KEY=0123456789abcdef01234567:0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
GHOST_CONTENT_API_KEY=your-content-key

# Illustration provider routing (TASK_047)
CLAUDE_MAGAZINE_ILLUSTRATION_PROVIDER=pollinations
CLAUDE_MAGAZINE_ILLUSTRATION_MONTHLY_USD_CAP=0.0

# HuggingFace image generation (optional free token path)
HUGGINGFACE_TOKEN=hf_...
HUGGINGFACE_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# OpenAI image generation (optional paid fallback)
# OPENAI_API_KEY=sk-...
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_QUALITY=low
# OPENAI_IMAGE_MODERATION=auto

# Figma sync (TASK_046 free REST path)
FIGMA_FILE_KEY=your-figma-file-key
FIGMA_ACCESS_TOKEN=figd_...

# Langfuse (LLM observability)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Source registry DB
SOURCE_DB_PATH=./data/source_registry.db

# Reddit OAuth ingestion (TASK_057)
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=claude-magazine/0.3 by /u/your_username

# External curation free-only budgets (TASK_058/TASK_059)
CLAUDE_MAGAZINE_AUTO_SUMMARIZER_MONTHLY_USD_CAP=0.0
CLAUDE_MAGAZINE_MONTHLY_CURATOR_MONTHLY_USD_CAP=0.0
QUALITY_REVIEW_MONTHLY_USD_CAP=0.0

# Human gates (TASK_060/TASK_061)
ARTICLE_BUDGET_DEFAULT_USD=1.0
G5_THRESHOLD_PCT=150.0
G5_SLA_MINUTES=30

# n8n Webhook
N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/...

# Notifications
NOTIFY_SLACK_WEBHOOK=https://hooks.slack.com/...
NOTIFY_EMAIL=editor@your-magazine.com

# n8n REST API
N8N_BASE_URL=https://your-n8n-instance.n8n.cloud
N8N_API_KEY=n8n_api_...
